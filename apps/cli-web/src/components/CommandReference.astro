---
import type { CommandDoc } from "../lib/types";
import CommandItem from "./CommandItem.astro";
import OptionRow from "./OptionRow.astro";
import cliData from "../data/cli.json";

const data = cliData as CommandDoc;
---


  {(data.global_options?.length ?? 0) > 0 && (
    <div class="mb-5">
      <div class="overflow-hidden rounded-lg border border-neutral-800/40 bg-neutral-900/30">
        <details class="border-b border-neutral-800/30 last:border-b-0">
          <summary class="group flex w-full cursor-pointer items-center gap-3 px-4 py-3 text-left">
            <span class="text-[10px] text-neutral-700 transition-transform duration-200 group-open:rotate-90">&#9656;</span>
            <span class="text-[11px] font-medium tracking-widest text-neutral-600 uppercase">Global options</span>
          </summary>
          <div class="pr-4 pb-4 pl-10">
            {data.global_options!.map((opt) => (
              <OptionRow opt={opt} />
            ))}
          </div>
        </details>
      </div>
    </div>
  )}

  {(data.subcommands?.length ?? 0) > 0 && (
    <div class="mt-8">
      <p class="mb-3 text-[11px] font-medium tracking-widest text-neutral-600 uppercase">Commands</p>
      <div class="overflow-hidden rounded-lg border border-neutral-800/40 bg-neutral-900/30">
        {data.subcommands!.map((sub) => (
          <CommandItem cmd={sub} />
        ))}
      </div>
    </div>
  )}

